{% extends 'base.html.twig' %}

{% block title %}Nouvelle Tâche{% endblock %}

{% block body %}
<div class="min-h-screen bg-gray-50 flex items-center justify-center p-4">
    <div class="bg-white w-full max-w-lg rounded-[24px] p-10 shadow-sm border border-gray-100">
        <h2 class="text-2xl font-bold mb-8 text-gray-900">Créer une nouvelle tâche</h2>
        
        <form action="{{ path('app_task_new') }}" method="POST" class="space-y-6">
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-2">Titre de la tâche</label>
                <input type="text" name="task_title" placeholder="Ex: Finir le projet Symfony" required 
                       class="w-full bg-gray-50 border border-gray-200 rounded-xl px-4 py-3 outline-none focus:border-black transition">
            </div>

    <div>
        <label for="priority">Priorité</label>
        <select name="task_priority" id="priority" class="border rounded p-2 w-full">
        {% for p in priorities %}
        <option value="{{p.id }}">{{ p.name }}</option>
        {% endfor %}
        </select>
    </div>

            <div>
        <label class="block text-sm font-semibold text-gray-700 mb-2">Dossier</label>
        <select name="task_folder" class="w-full bg-gray-50 border border-gray-200 rounded-xl px-4 py-3 outline-none focus:border-black transition">
        <option value="">Aucun dossier</option>
        
        {% for folder in folders %}
            <option value="{{ folder.id }}">{{ folder.name }}</option>
        {% endfor %}
         </select>
        </div>

            <div class="flex items-center justify-end gap-4 pt-6">
                <a href="{{ path('app_task_index') }}" class="text-gray-500 hover:text-gray-700 font-medium">Annuler</a>
                <button type="submit" class="bg-black text-white px-8 py-3 rounded-xl font-bold hover:bg-gray-800 transition">
                    Enregistrer la tâche
                </button>
            </div>
        </form>
    </div>
</div>
{% endblock %}