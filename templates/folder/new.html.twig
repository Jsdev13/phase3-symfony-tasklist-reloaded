{% extends 'base.html.twig' %}

{% block title %}Nouveau dossier{% endblock %}


{% block body %}
<div class="min-h-screen bg-[#F9FAFB] flex items-center justify-center p-4">
    <div class="bg-white w-full max-w-lg rounded-[24px] p-10 shadow-sm border border-gray-100">
        <h2 class="text-2xl font-bold mb-8 text-gray-900">Créer un nouveau dossier</h2>
    
        <form action="{{ path('app_folder_new') }}" method="POST" class="space-y-6">
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-2">Nom du dossier</label>
                <input type="text" name="folder_name" placeholder="Ex: Maison,Sport.." required 
                       class="w-full bg-gray-50 border border-gray-200 rounded-xl px-4 py-3 outline-none focus:border-black transition">
            </div>

            <div class="flex items-center justify-end gap-4 pt-6">
                <a href="{{ path('app_task_index') }}" class="text-gray-500 hover:text-gray-700 font-medium">Annuler</a>
                <button type="submit" class="bg-[#0F172A] text-white px-8 py-3 rounded-xl font-bold hover:bg-black transition">
                    Créer le dossier
                </button>
            </div>
        </form>
    </div>
</div>
{% endblock %}