
{% extends 'base.html.twig' %}

{% block title %}Register{% endblock %}

{% block body %}

<section class="h-screen bg-gray-200 flex justify-center items-center">

    <div class="w-[448px] bg-white border border-black/10 rounded-[14px] p-10">

        <div class="text-center mb-6">
            <h1 class="text-2xl font-bold mb-2">Gestion de Tâches</h1>
            <p class="text-gray-400 text-sm">Organisez votre journée efficacement</p>
        </div>
        
        <div class="flex gap-2 mb-6">
            <a href="{{ path('app_login') }}" class="flex-1 text-center py-2 text-gray-400 hover:text-gray-700 font-semibold">
                Connexion
            </a>
            <a href="{{ path('app_register') }}" class="flex-1 text-center py-2 bg-gray-200 rounded-lg font-semibold">
                Inscription
            </a>
        </div>
        
        {{ form_start(registrationForm) }}

            <div class="mb-4">
                {{ form_label(registrationForm.email, 'Email', {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-2'}}) }}
                {{ form_widget(registrationForm.email, {'attr': {'class': 'w-full bg-gray-100 rounded-lg px-4 py-3 border-0 focus:ring-2 focus:ring-blue-500', 'placeholder': 'votre@email.com'}}) }}
                {{ form_errors(registrationForm.email) }}
            </div>

            <div class="mb-4">
                {{ form_label(registrationForm.username, "Nom d'utilisateur", {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-2'}}) }}
                {{ form_widget(registrationForm.username, {'attr': {'class': 'w-full bg-gray-100 rounded-lg px-4 py-3 border-0 focus:ring-2 focus:ring-blue-500', 'placeholder': 'nom_utilisateur'}}) }}
                {{ form_errors(registrationForm.username) }}
            </div>

            <div class="mb-6">
                {{ form_label(registrationForm.plainPassword, 'Mot de passe', {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-2'}}) }}
                {{ form_widget(registrationForm.plainPassword, {'attr': {'class': 'w-full bg-gray-100 rounded-lg px-4 py-3 border-0 focus:ring-2 focus:ring-blue-500', 'placeholder': '••••••••'}}) }}
                {{ form_errors(registrationForm.plainPassword) }}
            </div>

            <div class="hidden">
                {{ form_widget(registrationForm.agreeTerms, {'attr': {'checked': 'checked'}}) }}
            </div>
            
            <button type="submit" class="w-full bg-black text-white font-semibold py-3 rounded-lg hover:bg-gray-800 transition">
                S'inscrire
            </button>

        {{ form_end(registrationForm) }}
    </div>

</section>
{% endblock %}